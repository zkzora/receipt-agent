# ─── Core ────────────────────────────────────────────────────────────────
# LLM for the classify + judge steps only. OpenAI-compatible endpoint — set
# OPENAI_API_BASE to your provider (OpenRouter shown) and OPENAI_API_KEY to its
# key. LLM_MODEL is that provider's model id. The engine degrades gracefully
# (deterministic verdict, no narrative) if the key is absent.
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
LLM_MODEL=anthropic/claude-haiku-4.5
# Optional / back-compat: unused while routing through OPENAI_API_BASE above.
ANTHROPIC_API_KEY=

# ─── CAP / CROO ──────────────────────────────────────────────────────────
# CAP_MODE controls how the agent talks to the CROO Agent Protocol:
#   mock = no network/creds; a synthetic order runs through the pipe locally
#   live = use the real CROO SDK (requires the keys below)
CAP_MODE=mock
CROO_SDK_KEY=
# CROO backend endpoints the @croo-network/sdk targets (defaults shown).
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
AGENT_WALLET_ADDRESS=
# Optional / informational — the agent wallet + on-chain settlement are custodial
# on CROO's side; the SDK authenticates with CROO_SDK_KEY alone.
AGENT_WALLET_PRIVATE_KEY=

# Service registration (off-chain config in the CROO dashboard mirrors these)
SERVICE_PRICE_USDC=0.5
SERVICE_SLA_SECONDS=300

# ─── Chain / data providers ──────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=

# ─── Off-chain evidence (HONESTY axis — reads the project's own pages) ────
# Primary discovery (DexScreener websites/socials) is keyless. A search key just
# adds discovery of sites the project didn't register; X/Twitter is never fetched.
OFFCHAIN_ENABLED=1
SEARCH_PROVIDER=none
SEARCH_API_KEY=

# ─── A2A sub-agent serviceIds (blank = use local fallback) ───────────────
SUBAGENT_SECURITY_SERVICE_ID=
SUBAGENT_LIQUIDITY_SERVICE_ID=
SUBAGENT_DEPLOYER_SERVICE_ID=

# ─── Runtime ─────────────────────────────────────────────────────────────
PORT=8787
LOG_LEVEL=info
DEV_PRETTY_LOGS=0
# Hard ceiling for the whole pipeline; must stay under the service SLA.
PIPELINE_BUDGET_MS=240000
